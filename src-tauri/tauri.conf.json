{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "自动点击流程台",
  "version": "1.9.0",
  "identifier": "com.shree.clickflow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "自动点击流程台",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMDA3NDcyREIwMzBCMzgKUldRNEN3UGJjblFBU2lxMHFEak9QNGZvL1JPQXV2NHY2UU85RExKbTNLMTh4d01GOWI3eTBMQlkK",
      "endpoints": [
        "https://gitee.com/nbshree/shree-macro-flow-tauri/raw/updater-feed/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Shree Macro Flow",
    "shortDescription": "自动点击与键盘宏流程工具",
    "longDescription": "支持坐标采集、鼠标点击、键盘输入、循环执行、全局热键和多方案管理。",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "startMenuFolder": "自动点击流程台"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
